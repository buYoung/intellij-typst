<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.livteam.typninja</id>
    <name>Typst</name>
    <vendor>buyoung</vendor>
    <description><![CDATA[
        <p>Native <b>Typst</b> language support for IntelliJ-based IDEs.</p>
        <ul>
            <li>Recognises <code>.typ</code> files as Typst source files.</li>
            <li>Lexer-based syntax highlighting with customisable colour settings (Settings → Editor → Color Scheme → Typst).</li>
            <li>Recoverable parser and PSI that keeps the editor usable on incomplete or malformed input.</li>
            <li>Conservative code formatter — normalises spacing and indentation inside closed code groups (including multi-line blocks, arrays and dictionaries) while preserving markup prose. Indentation follows Settings → Code Style → Typst.</li>
            <li>Brace matching for <code>()</code>, <code>{}</code> and <code>[]</code>, and code folding for closed multi-line blocks, groups and content blocks.</li>
            <li>Line-comment toggling (<code>//</code>) via the standard Code → Comment with Line Comment action.</li>
            <li>Go To Declaration (Cmd/Ctrl+Click): file-local variables and functions, <code>@reference</code> to its <code>&lt;label&gt;</code>, relative <code>#import</code> paths and imported names, and Typst standard-library builtins.</li>
            <li>Declaration-side Find Usages for supported file-local <code>#let</code> variables and functions.</li>
            <li>Contextual completion for local symbols, import members, labels, named arguments, relative paths, keywords and known Typst standard-library symbols.</li>
            <li>Weak diagnostics for high-confidence unresolved references, labels and relative imports/includes.</li>
            <li>Quick documentation and signature help for supported user and builtin symbols.</li>
            <li>Structure view, workspace symbol search, occurrence highlighting, URL/relative-path links, color previews, heading intentions and comment-aware Enter handling.</li>
        </ul>
        <p>This is an MVP release. Cross-package <code>@preview</code> imports, full Typst type checking, package registry lookup, Typst rendering and PDF preview are not included.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <!-- Language and file type registrations -->
    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Typst" displayType="BALLOON" isLogByDefault="true"/>
        <postStartupActivity implementation="com.livteam.typninja.preview.TypstAutoCompileStartupActivity"/>
        <statusBarWidgetFactory id="com.livteam.typninja.status"
                                implementation="com.livteam.typninja.preview.TypstStatusBarWidgetFactory"
                                order="last"/>
        <fileType name="Typst"
                  implementationClass="com.livteam.typninja.language.TypstFileType"
                  fieldName="INSTANCE"
                  language="Typst"
                  extensions="typ"/>
        <lang.parserDefinition language="Typst"
                               implementationClass="com.livteam.typninja.language.parser.TypstParserDefinition"/>
        <lang.syntaxHighlighterFactory language="Typst"
                                        implementationClass="com.livteam.typninja.language.highlighting.TypstSyntaxHighlighterFactory"/>
        <annotator language="Typst"
                   implementationClass="com.livteam.typninja.language.highlighting.TypstAnnotator"/>
        <annotator language="Typst"
                   implementationClass="com.livteam.typninja.language.diagnostics.TypstDiagnosticsAnnotator"/>
        <colorSettingsPage implementation="com.livteam.typninja.language.highlighting.TypstColorSettingsPage"/>
        <projectConfigurable instance="com.livteam.typninja.settings.TypstSettingsConfigurable"
                             id="com.livteam.typninja.settings"
                             displayName="Typst"
                             parentId="tools"/>
        <additionalLibraryRootsProvider implementation="com.livteam.typninja.language.references.TypstPackageLibraryRootsProvider"/>
        <toolWindow id="Typst Preview"
                    anchor="right"
                    factoryClass="com.livteam.typninja.preview.TypstPreviewToolWindowFactory"/>
        <toolWindow id="Typst"
                    anchor="left"
                    secondary="true"
                    factoryClass="com.livteam.typninja.language.editor.TypstWorkspaceToolWindowFactory"/>
        <lang.formatter language="Typst"
                        implementationClass="com.livteam.typninja.language.formatting.TypstFormattingModelBuilder"/>
        <lang.commenter language="Typst"
                        implementationClass="com.livteam.typninja.language.TypstCommenter"/>
        <langCodeStyleSettingsProvider
                implementation="com.livteam.typninja.language.formatting.TypstLanguageCodeStyleSettingsProvider"/>
        <lang.braceMatcher language="Typst"
                           implementationClass="com.livteam.typninja.language.TypstBraceMatcher"/>
        <lang.foldingBuilder language="Typst"
                             implementationClass="com.livteam.typninja.language.folding.TypstFoldingBuilder"/>
        <lang.findUsagesProvider language="Typst"
                                 implementationClass="com.livteam.typninja.language.references.TypstFindUsagesProvider"/>
        <usageTypeProvider implementation="com.livteam.typninja.language.references.TypstUsageTypeProvider"/>
        <lang.refactoringSupport language="Typst"
                                 implementationClass="com.livteam.typninja.language.references.TypstRefactoringSupportProvider"/>
        <typeDeclarationProvider implementation="com.livteam.typninja.language.references.TypstTypeDeclarationProvider"/>
        <completion.contributor language="Typst"
                                implementationClass="com.livteam.typninja.language.completion.TypstCompletionContributor"/>
        <psi.referenceContributor language="Typst"
                                  implementation="com.livteam.typninja.language.editor.TypstLinkReferenceContributor"/>
        <lang.documentationProvider language="Typst"
                                    implementationClass="com.livteam.typninja.language.documentation.TypstDocumentationProvider"/>
        <codeInsight.parameterInfo language="Typst"
                                   implementationClass="com.livteam.typninja.language.documentation.TypstParameterInfoHandler"/>
        <lang.psiStructureViewFactory language="Typst"
                                      implementationClass="com.livteam.typninja.language.structure.TypstStructureViewFactory"/>
        <fileBasedIndex implementation="com.livteam.typninja.language.analysis.TypstExportedSymbolIndex"/>
        <fileBasedIndex implementation="com.livteam.typninja.language.analysis.TypstLabelIndex"/>
        <fileBasedIndex implementation="com.livteam.typninja.language.analysis.TypstBibliographyIndex"/>
        <gotoSymbolContributor implementation="com.livteam.typninja.language.structure.TypstSymbolContributor"/>
        <highlightUsagesHandlerFactory implementationClass="com.livteam.typninja.language.editor.TypstHighlightUsagesHandlerFactory"/>
        <runLineMarkerContributor language="Typst"
                                  implementationClass="com.livteam.typninja.language.editor.TypstRunLineMarkerContributor"/>
        <extendWordSelectionHandler implementationClass="com.livteam.typninja.language.editor.TypstWordSelectionHandler"
                                    order="first"/>
        <lang.surroundDescriptor language="Typst"
                                 implementationClass="com.livteam.typninja.language.editor.TypstSurroundDescriptor"/>
        <colorProvider implementationClass="com.livteam.typninja.language.editor.TypstColorProvider"/>
        <codeInsight.declarativeInlayProvider language="Typst"
                                              providerId="typst.parameters"
                                              bundle="messages.MyBundle"
                                              nameKey="inlay.typst.parameters.name"
                                              descriptionKey="inlay.typst.parameters.description"
                                              implementationClass="com.livteam.typninja.language.editor.TypstInlayHintsProvider"/>
        <codeInsight.declarativeInlayProvider language="Typst"
                                              providerId="typst.package.version"
                                              bundle="messages.MyBundle"
                                              nameKey="inlay.typst.package.version.name"
                                              descriptionKey="inlay.typst.package.version.description"
                                              implementationClass="com.livteam.typninja.language.editor.TypstPackageVersionInlayHintsProvider"/>
        <enterHandlerDelegate implementation="com.livteam.typninja.language.actions.TypstEnterHandler"/>
        <typedHandler implementation="com.livteam.typninja.language.editor.TypstTypedHandler"/>
        <fileDropHandler implementation="com.livteam.typninja.language.editor.TypstResourceDropHandler"/>
        <intentionAction>
            <language>Typst</language>
            <className>com.livteam.typninja.language.actions.TypstIncreaseHeadingLevelIntention</className>
            <category>Typst</category>
        </intentionAction>
        <intentionAction>
            <language>Typst</language>
            <className>com.livteam.typninja.language.actions.TypstDecreaseHeadingLevelIntention</className>
            <category>Typst</category>
        </intentionAction>
        <intentionAction>
            <language>Typst</language>
            <className>com.livteam.typninja.language.actions.TypstConvertMathToBlockIntention</className>
            <category>Typst</category>
        </intentionAction>
        <intentionAction>
            <language>Typst</language>
            <className>com.livteam.typninja.language.actions.TypstConvertMathToInlineIntention</className>
            <category>Typst</category>
        </intentionAction>
    </extensions>

    <actions>
        <action id="com.livteam.typninja.preview"
                class="com.livteam.typninja.language.actions.TypstPreviewAction"
                text="Preview Typst"
                description="Compile the saved Typst file with the configured Typst executable">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <action id="com.livteam.typninja.export"
                class="com.livteam.typninja.language.actions.TypstExportAction"
                text="Export Typst"
                description="Export the saved Typst file with the configured Typst executable">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>

</idea-plugin>
